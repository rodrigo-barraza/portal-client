# ════════════════════════════════════════════════════════════════
#  Portal — Local Environment Overrides
# ════════════════════════════════════════════════════════════════
#  These values override secrets from Vault and vault/.env.
#  Only add variables you want to change for local development.
#
#  To use:  cp .env.example .env
#
#  Resolution order (first wins):
#    1. process.env (manual env vars)
#    2. This file (.env)
#    3. Vault service
#    4. Shared vault/.env fallback
# ════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
# PORTAL_PORT="4000"

# ── Vault Connection ──────────────────────────────────────────
# VAULT_SERVICE_URL="http://<host>:5599"
# VAULT_SERVICE_TOKEN=""

# ── API (backend for this frontend) ───────────────────────────
# PORTAL_API_URL="http://localhost:4001"

# ── Auth (Google SSO) ─────────────────────────────────────────
# These are resolved from Vault in dev. For production standalone,
# they must be present in .env.deploy (→ Docker .env at runtime).
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# AUTH_SECRET=""
# AUTH_ALLOWED_EMAILS=""
