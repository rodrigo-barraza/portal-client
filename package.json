{
  "name": "portal-client",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev -p $(node -e \"import('./config.js').then(c=>console.log(c.PORT))\")",
    "prebuild": "node scripts/generate-component-catalog.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "bash deploy.sh",
    "deploy:dry": "bash deploy.sh --dry-run",
    "catalog:generate": "node scripts/generate-component-catalog.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rodrigo-barraza/components": "git+https://github.com/rodrigo-barraza/components-library.git",
    "@rodrigo-barraza/utilities": "git+https://github.com/rodrigo-barraza/utilities-library.git",
    "lucide-react": "^0.577.0",
    "luxon": "^3.7.2",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}