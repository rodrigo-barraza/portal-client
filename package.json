{
  "name": "portal-client",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "prebuild": "node scripts/generate-component-catalog.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "bash deploy.sh",
    "deploy:dry": "bash deploy.sh --dry-run",
    "catalog:generate": "node scripts/generate-component-catalog.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rodrigo-barraza/components-library": "git+https://github.com/rodrigo-barraza/components-library.git",
    "@rodrigo-barraza/utilities-library": "git+https://github.com/rodrigo-barraza/utilities-library.git",
    "lucide-react": "^1.14.0",
    "luxon": "^3.7.2",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vite": "^8.0.11",
    "@types/testing-library__jest-dom": "^5.14.9"
  }
}
